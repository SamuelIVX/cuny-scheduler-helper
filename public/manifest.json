{
    "manifest_version": 3,
    "name": "CUNY Scheduler Helper",
    "version": "1.0.0",
    "description": "Shows professor ratings and reviews when hovering over courses in the CUNY Schedule Builder.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "*://*.cuny.edu/*",
        "*://www.ratemyprofessors.com/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://sb.cunyfirst.cuny.edu/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icon16.png",
            "32": "icon32.png"
        }
    },
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}